[layer_names]

3d_physics/layer_1="world_static"
3d_physics/layer_2="world_dynamic"
3d_physics/layer_3="character"
3d_physics/layer_4="interactable"

[physics]

3d/run_on_separate_thread=true
3d/physics_engine="Jolt Physics"
common/physics_interpolation=true

[rendering]

rendering_device/driver.windows="d3d12"
textures/default_filters/anisotropic_filtering_level=3
anti_aliasing/quality/screen_space_aa=2
